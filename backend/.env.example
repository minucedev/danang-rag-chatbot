# Required: Qdrant Cloud credentials
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=your-api-key-here

# Recommended: avoids HuggingFace rate limits when downloading BAAI/bge-m3
HF_TOKEN=your-huggingface-token-here

# Local LLM via llama.cpp GGUF.
# Relative paths are resolved from the directory where uvicorn is started.
# This repo's docs run `cd backend` before uvicorn, so this points to backend/models/...
LLM_GGUF_PATH=models/qwen2.5-3b-instruct-q4_k_m.gguf
LLM_N_CTX=4096
LLM_N_GPU_LAYERS=-1

# Optional embedding override
EMBED_MODEL_NAME=BAAI/bge-m3

# Local SQLite
DB_PATH=data/chats.db

# Generation / retrieval defaults
DEFAULT_MAX_TOKENS=512
DEFAULT_TEMPERATURE=0.2
DEFAULT_TOP_K=5
SCORE_THRESHOLD=0.3

# Optional: use a short cache path on Windows to avoid long-path errors
# HF_HOME=D:\hf_cache

# Optional Gemini fallback.
# Leave GEMINI_API_KEY empty to disable fallback. When enabled, Gemini is used only
# after Qdrant retrieval returns zero results.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_SECONDS=30
GEMINI_FALLBACK_PREFIX_DISCLAIMER=true

# Event crawler (SerpAPI google_events). Để trống = crawler bị skip.
SERPAPI_KEY=

# Crawler runtime knobs
CACHE_TTL_HOURS=24
DEFAULT_RADIUS_KM=30
DEFAULT_EVENT_DAYS=7
DEFAULT_LIMIT=50

# Bảo vệ POST /api/admin/crawl/events. Empty = endpoint trả 503.
ADMIN_TOKEN=
